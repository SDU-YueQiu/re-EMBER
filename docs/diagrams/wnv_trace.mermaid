stateDiagram-v2
    state "SUCCESS\n写回 targetWNV" as SUCCESS
    state "BOUNDARY_HIT" as BOUNDARY_HIT
    state "START_AT_POLYGON" as START_AT_POLYGON
    state "END_AT_POLYGON" as END_AT_POLYGON
    state "INVALID_SEGMENT" as INVALID_SEGMENT
    state "INVALID_POLYGON" as INVALID_POLYGON
    state "FAIL" as FAIL

    [*] --> BuildPathPoints
    BuildPathPoints: 预处理 pathPoints
    BuildPathPoints --> INVALID_SEGMENT: 任一 seg 无效
    BuildPathPoints --> PolygonLoop: pathPoints 构建完成

    state PolygonLoop {
        [*] --> ValidatePolygon

        ValidatePolygon: 当前 poly
        ValidatePolygon --> INVALID_POLYGON: poly 无效
        ValidatePolygon --> FAIL: WNTV.size != tmpwnv.size
        ValidatePolygon --> FirstPoint

        FirstPoint: 分类 path 起点
        FirstPoint --> BOUNDARY_HIT: ON_BOUNDARY
        FirstPoint --> START_AT_POLYGON: ON_POLYGON_STRICT
        FirstPoint --> SegmentLoop: OFF_* / ON_PLANE_OUTSIDE

        state SegmentLoop {
            [*] --> Running

            Running: 逐段扫描
            Running --> BOUNDARY_HIT: curr = ON_BOUNDARY
            Running --> BOUNDARY_HIT: curr = ON_POLYGON_STRICT 且 prev = ON_PLANE_OUTSIDE
            Running --> InPolygonRun: curr = ON_POLYGON_STRICT 且 prevSide != 0
            Running --> FAIL: curr = ON_POLYGON_STRICT 且 prev 非 ON_POLYGON_STRICT 且 prevSide = 0
            Running --> BOUNDARY_HIT: curr = ON_PLANE_OUTSIDE 且 prev = ON_POLYGON_STRICT
            Running --> Running: curr = ON_PLANE_OUTSIDE
            Running --> DirectCross: curr = OFF_* 且 prevSide != 0 且 prevSide != currSide
            Running --> Running: curr = OFF_* 且 (prevSide = 0 或 prevSide = currSide)
            Running --> [*]: 所有 segment 已处理

            InPolygonRun: insideRun = true
            InPolygonRun --> InPolygonRun: curr = ON_POLYGON_STRICT
            InPolygonRun --> BOUNDARY_HIT: curr = ON_BOUNDARY
            InPolygonRun --> BOUNDARY_HIT: curr = ON_PLANE_OUTSIDE
            InPolygonRun --> ExitRun: curr = OFF_*
            InPolygonRun --> [*]: 所有 segment 已处理

            ExitRun --> FAIL: accumulateWNTV 失败
            ExitRun --> Running: sigma = (pendingSide - currSide) / 2

            DirectCross --> Running: !intersectionSegmentPolygon
            DirectCross --> BOUNDARY_HIT: 交点不在严格内部
            DirectCross --> FAIL: accumulateWNTV 失败
            DirectCross --> Running: 严格内部交点 / sigma = (prevSide - currSide) / 2
        }

        SegmentLoop --> EndCheck
        EndCheck --> END_AT_POLYGON: insideRun = true 或 prev = ON_POLYGON_STRICT
        EndCheck --> NextPolygon: 其余情况

        NextPolygon --> ValidatePolygon: 还有下一个 poly
        NextPolygon --> [*]: 所有 poly 已处理
    }

    PolygonLoop --> SUCCESS